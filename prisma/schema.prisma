generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  SUPPORT_AGENT

  @@map("admin_role")
}

enum BalanceDisplay {
  HONEY
  USD
  BOTH

  @@map("balance_display")
}

enum EmailTokenType {
  VERIFY_EMAIL
  RESET_PASSWORD

  @@map("email_token_type")
}

enum FraudEventType {
  VPN_DETECTED
  MULTI_ACCOUNT_IP
  MULTI_ACCOUNT_DEVICE
  RAPID_COMPLETIONS
  CHARGEBACK
  KYC_REJECTED
  GEO_MISMATCH
  SCORE_DECAY

  @@map("fraud_event_type")
}

enum IpType {
  RESIDENTIAL
  VPN
  PROXY
  DATACENTER
  TOR

  @@map("ip_type")
}

enum KycDocType {
  PASSPORT
  DRIVERS_LICENSE
  NATIONAL_ID

  @@map("kyc_doc_type")
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("kyc_status")
}

enum OfferStatus {
  CREDITED
  HELD
  REVERSED

  @@map("offer_status")
}

enum PostbackResult {
  CREDITED
  DUPLICATE
  REJECTED_IP
  REJECTED_SIG
  REJECTED_USER
  ERROR

  @@map("postback_result")
}

enum ProviderType {
  OFFERWALL
  SURVEY_WALL
  WATCH_WALL

  @@map("provider_type")
}

enum RaceStatus {
  ACTIVE
  FINALIZING
  COMPLETED

  @@map("race_status")
}

enum RaceType {
  DAILY
  MONTHLY

  @@map("race_type")
}

enum ReportReason {
  SPAM
  ABUSE
  HARASSMENT
  OTHER

  @@map("report_reason")
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED

  @@map("report_status")
}

enum SettingCategory {
  GENERAL
  WITHDRAWALS
  RACES
  STREAKS
  VIP
  REFERRALS

  @@map("setting_category")
}

enum SettingType {
  STRING
  INT
  FLOAT
  BOOLEAN
  JSON

  @@map("setting_type")
}

enum SignatureMethod {
  HMAC_SHA256
  HMAC_MD5
  SECRET_PARAM
  NONE

  @@map("signature_method")
}

enum TicketCategory {
  WITHDRAWAL
  OFFER_NOT_CREDITED
  ACCOUNT
  KYC
  OTHER

  @@map("ticket_category")
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT

  @@map("ticket_priority")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED

  @@map("ticket_status")
}

enum TransactionSource {
  OFFER
  WITHDRAWAL
  REFERRAL
  RACE
  PROMO
  STREAK
  VIP
  SIGNUP
  ADMIN

  @@map("transaction_source")
}

enum TransactionType {
  OFFER_EARNING
  SURVEY_EARNING
  REFERRAL_COMMISSION
  STREAK_BONUS
  RACE_PRIZE
  VIP_BONUS
  PROMO_CODE
  SIGNUP_BONUS
  WITHDRAWAL
  ADMIN_ADJUSTMENT
  CHARGEBACK

  @@map("transaction_type")
}

enum VipTier {
  NONE
  BRONZE
  SILVER
  GOLD
  PLATINUM

  @@map("vip_tier")
}

enum WithdrawalMethod {
  PAYPAL
  BTC
  ETH
  LTC
  SOL
  AMAZON
  STEAM
  ROBLOX
  VISA

  @@map("withdrawal_method")
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  FAILED

  @@map("withdrawal_status")
}

// ─── MODELS ─────────────────────────────────────────────────────────────────────

model Achievement {
  id            String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  slug          String            @unique
  name          String
  description   String
  icon          String
  color         String
  criteriaType  String            @map("criteria_type")
  criteriaValue Int               @map("criteria_value")
  sortOrder     Int               @default(0) @map("sort_order")
  achievements  UserAchievement[]

  @@map("achievement")
}

model AdminUser {
  id              String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  email           String            @unique @db.Citext
  passwordHash    String            @map("password_hash")
  name            String
  role            AdminRole         @default(MODERATOR)
  totpSecret      String?           @map("totp_secret")
  totpEnabled     Boolean           @default(false) @map("totp_enabled")
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  lastLoginAt     DateTime?         @map("last_login_at") @db.Timestamptz(6)
  auditLogs       AuditLog[]
  chatMessages    ChatMessage[]
  chatReports     ChatReport[]
  kycReviews      KycVerification[]
  settings        PlatformSetting[]
  promoCodes      PromoCode[]
  tickets         SupportTicket[]
  withdrawals     Withdrawal[]

  @@map("admin_user")
}

model AuditLog {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  adminId     String   @map("admin_id")
  action      String
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  beforeState Json?    @map("before_state")
  afterState  Json?    @map("after_state")
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  admin       AdminUser @relation(fields: [adminId], references: [id], onUpdate: NoAction)

  @@index([adminId, createdAt(sort: Desc)], map: "idx_al_admin")
  @@index([createdAt(sort: Desc)], map: "idx_al_created")
  @@index([targetType, targetId], map: "idx_al_target", where: raw("(target_id IS NOT NULL)"))
  @@map("audit_log")
}

model ChatMessage {
  id              String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId          String       @map("user_id")
  room            String       @default("general")
  content         String       @db.VarChar(200)
  isSystemMessage Boolean      @default(false) @map("is_system_message")
  isDeleted       Boolean      @default(false) @map("is_deleted")
  deletedBy       String?      @map("deleted_by")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedByAdmin  AdminUser?   @relation(fields: [deletedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reports         ChatReport[]

  @@index([room, createdAt(sort: Desc)], map: "idx_chat_room_time")
  @@index([userId], map: "idx_chat_user")
  @@map("chat_message")
}

model ChatReport {
  id         String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  messageId  String       @map("message_id")
  reportedBy String       @map("reported_by")
  reason     ReportReason
  detail     String?
  status     ReportStatus @default(PENDING)
  reviewedBy String?      @map("reviewed_by")
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  reviewedAt DateTime?    @map("reviewed_at") @db.Timestamptz(6)
  message    ChatMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reporter   User         @relation(fields: [reportedBy], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reviewer   AdminUser?   @relation(fields: [reviewedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status], map: "idx_cr_pending", where: raw("(status = 'PENDING'::report_status)"))
  @@map("chat_report")
}

model DeviceFingerprint {
  id               String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId           String   @map("user_id")
  fingerprintHash  String   @map("fingerprint_hash")
  userAgent        String?  @map("user_agent")
  screenResolution String?  @map("screen_resolution")
  timezone         String?
  ip               String
  ipType           IpType?  @map("ip_type")
  ipCountry        String?  @map("ip_country") @db.Char(2)
  ipFraudScore     Float?   @map("ip_fraud_score") @db.Real
  isSignupDevice   Boolean  @default(false) @map("is_signup_device")
  firstSeenAt      DateTime @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt       DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([fingerprintHash], map: "idx_df_hash")
  @@index([ip], map: "idx_df_ip")
  @@index([userId], map: "idx_df_user")
  @@map("device_fingerprint")
}

model EmailToken {
  id        String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String         @map("user_id")
  token     String         @unique @default(dbgenerated("encode(gen_random_bytes(32), 'hex'::text)"))
  type      EmailTokenType
  expiresAt DateTime       @map("expires_at") @db.Timestamptz(6)
  used      Boolean        @default(false)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_email_token_user")
  @@map("email_token")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model FeaturedOffer {
  id              String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  title           String
  requirement     String
  providerName    String   @map("provider_name")
  providerLogoUrl String?  @map("provider_logo_url")
  posterImageUrl  String?  @map("poster_image_url")
  appIconUrl      String?  @map("app_icon_url")
  rewardHoney     Int      @map("reward_honey")
  category        String
  externalUrl     String?  @map("external_url")
  completions     Int      @default(0)
  rating          Float?   @db.Real
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([isActive, sortOrder], map: "idx_fo_active", where: raw("(is_active = true)"))
  @@map("featured_offer")
}

model FraudEvent {
  id          String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId      String         @map("user_id")
  eventType   FraudEventType @map("event_type")
  scoreImpact Float          @map("score_impact") @db.Real
  scoreAfter  Float          @map("score_after") @db.Real
  detail      String
  evidence    Json?
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt(sort: Desc)], map: "idx_fe_user")
  @@map("fraud_event")
}

model KycVerification {
  id               String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId           String     @map("user_id")
  documentType     KycDocType @map("document_type")
  documentFrontUrl String     @map("document_front_url")
  documentBackUrl  String?    @map("document_back_url")
  selfieUrl        String     @map("selfie_url")
  status           KycStatus  @default(PENDING)
  reviewedBy       String?    @map("reviewed_by")
  rejectionReason  String?    @map("rejection_reason")
  reviewedAt       DateTime?  @map("reviewed_at") @db.Timestamptz(6)
  submittedAt      DateTime   @default(now()) @map("submitted_at") @db.Timestamptz(6)
  reviewer         AdminUser? @relation(fields: [reviewedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user             User       @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([status], map: "idx_kyc_status", where: raw("(status = 'PENDING'::kyc_status)"))
  @@index([userId], map: "idx_kyc_user")
  @@map("kyc_verification")
}

model Notification {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String   @map("user_id")
  type      String
  title     String
  body      String
  link      String?
  icon      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, isRead, createdAt(sort: Desc)], map: "idx_notif_user_unread")
  @@map("notification")
}

model OfferCompletion {
  id                  String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId              String            @map("user_id")
  providerId          String            @map("provider_id")
  externalTxId        String            @unique @map("external_tx_id")
  externalOfferId     String?           @map("external_offer_id")
  offerName           String            @map("offer_name")
  offerCategory       String?           @map("offer_category")
  payoutToUsCents     Int               @map("payout_to_us_cents")
  rewardToUserHoney   Int               @map("reward_to_user_honey")
  platformMarginHoney Int               @map("platform_margin_honey")
  vipBonusHoney       Int               @default(0) @map("vip_bonus_honey")
  status              OfferStatus       @default(CREDITED)
  holdReason          String?           @map("hold_reason")
  heldUntil           DateTime?         @map("held_until") @db.Timestamptz(6)
  reversalReason      String?           @map("reversal_reason")
  reversedAt          DateTime?         @map("reversed_at") @db.Timestamptz(6)
  userIp              String?           @map("user_ip")
  userCountry         String?           @map("user_country") @db.Char(2)
  rawPostback         Json              @map("raw_postback")
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  provider            OfferwallProvider @relation(fields: [providerId], references: [id], onUpdate: NoAction)
  user                User              @relation(fields: [userId], references: [id], onUpdate: NoAction)
  referralEarnings    ReferralEarning[]

  @@index([createdAt(sort: Desc)], map: "idx_oc_created")
  @@index([providerId], map: "idx_oc_provider")
  @@index([status], map: "idx_oc_status", where: raw("(status <> 'CREDITED'::offer_status)"))
  @@index([userId], map: "idx_oc_user")
  @@map("offer_completion")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model OfferwallProvider {
  id               String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  slug             String            @unique
  name             String
  logoUrl          String?           @map("logo_url")
  type             ProviderType      @default(OFFERWALL)
  postbackSecret   String            @map("postback_secret")
  postbackIps      String[]          @default([]) @map("postback_ips")
  signatureMethod  SignatureMethod   @default(HMAC_SHA256) @map("signature_method")
  iframeBaseUrl    String?           @map("iframe_base_url")
  revenueSharePct  Int               @default(80) @map("revenue_share_pct")
  bonusBadgePct    Int               @default(0) @map("bonus_badge_pct")
  isActive         Boolean           @default(true) @map("is_active")
  sortOrder        Int               @default(0) @map("sort_order")
  notes            String?
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  offerCompletions OfferCompletion[]
  postbackLogs     PostbackLog[]

  @@map("offerwall_provider")
}

model PlatformSetting {
  key         String          @id
  value       String
  type        SettingType     @default(STRING)
  category    SettingCategory @default(GENERAL)
  description String
  updatedAt   DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  updatedBy   String?         @map("updated_by")
  admin       AdminUser?      @relation(fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("platform_setting")
}

model PostbackLog {
  id            String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  providerId    String            @map("provider_id")
  rawUrl        String            @map("raw_url")
  sourceIp      String            @map("source_ip")
  result        PostbackResult
  errorDetail   String?           @map("error_detail")
  userId        String?           @map("user_id")
  externalTxId  String?           @map("external_tx_id")
  processingMs  Int?              @map("processing_ms")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  provider      OfferwallProvider @relation(fields: [providerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt(sort: Desc)], map: "idx_pbl_created")
  @@index([providerId, createdAt(sort: Desc)], map: "idx_pbl_provider_time")
  @@index([result], map: "idx_pbl_result", where: raw("(result <> 'CREDITED'::postback_result)"))
  @@map("postback_log")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model PromoCode {
  id                  String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  code                String            @unique
  rewardHoney         Int               @map("reward_honey")
  maxUses             Int?              @map("max_uses")
  usedCount           Int               @default(0) @map("used_count")
  requiresMinEarnings Boolean           @default(false) @map("requires_min_earnings")
  minEarningsHoney    Int               @default(0) @map("min_earnings_honey")
  isActive            Boolean           @default(true) @map("is_active")
  expiresAt           DateTime?         @map("expires_at") @db.Timestamptz(6)
  createdBy           String?           @map("created_by")
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  admin               AdminUser?        @relation(fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  redemptions         PromoRedemption[]

  @@map("promo_code")
}

model PromoRedemption {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId      String    @map("user_id")
  promoCodeId String    @map("promo_code_id")
  redeemedAt  DateTime  @default(now()) @map("redeemed_at") @db.Timestamptz(6)
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onUpdate: NoAction)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, promoCodeId])
  @@map("promo_redemption")
}

model Race {
  id                 String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  type               RaceType
  title              String
  prizePoolUsdCents  Int         @map("prize_pool_usd_cents")
  prizeDistribution  Json        @map("prize_distribution")
  startsAt           DateTime    @map("starts_at") @db.Timestamptz(6)
  endsAt             DateTime    @map("ends_at") @db.Timestamptz(6)
  status             RaceStatus  @default(ACTIVE)
  finalizedAt        DateTime?   @map("finalized_at") @db.Timestamptz(6)
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  entries            RaceEntry[]

  @@index([status, type], map: "idx_race_active", where: raw("(status = 'ACTIVE'::race_status)"))
  @@map("race")
}

model RaceEntry {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  raceId    String   @map("race_id")
  userId    String   @map("user_id")
  points    Int      @default(0)
  finalRank Int?     @map("final_rank")
  prizeHoney Int?    @map("prize_honey")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([raceId, userId])
  @@index([raceId, points(sort: Desc)], map: "idx_re_leaderboard")
  @@map("race_entry")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ReferralEarning {
  id                String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  referrerId        String          @map("referrer_id")
  earnerId          String          @map("earner_id")
  offerCompletionId String          @map("offer_completion_id")
  earnerRewardHoney Int             @map("earner_reward_honey")
  commissionPct     Int             @map("commission_pct")
  commissionHoney   Int             @map("commission_honey")
  transactionId     String          @map("transaction_id")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  earner            User            @relation("referralEarningsAsEarner", fields: [earnerId], references: [id], onUpdate: NoAction)
  offerCompletion   OfferCompletion @relation(fields: [offerCompletionId], references: [id], onUpdate: NoAction)
  referrer          User            @relation("referralEarningsAsReferrer", fields: [referrerId], references: [id], onUpdate: NoAction)

  @@index([earnerId], map: "idx_re_earner")
  @@index([referrerId, createdAt(sort: Desc)], map: "idx_re_referrer")
  @@map("referral_earning")
}

model Session {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String   @map("user_id")
  token      String   @unique
  device     String?
  ip         String?
  fingerprint String?
  lastActive DateTime @default(now()) @map("last_active")  @db.Timestamptz(6)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expiresAt], map: "idx_session_expires")
  @@index([userId], map: "idx_session_user")
  @@map("session")
}

model SupportMessage {
  id            String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  ticketId      String        @map("ticket_id")
  senderId      String        @map("sender_id")
  isAdmin       Boolean       @default(false) @map("is_admin")
  content       String
  attachmentUrl String?       @map("attachment_url")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([ticketId, createdAt], map: "idx_sm_ticket")
  @@map("support_message")
}

model SupportTicket {
  id                  String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId              String           @map("user_id")
  subject             String
  category            TicketCategory   @default(OTHER)
  status              TicketStatus     @default(OPEN)
  priority            TicketPriority   @default(NORMAL)
  assignedTo          String?          @map("assigned_to")
  relatedOfferId      String?          @map("related_offer_id")
  relatedWithdrawalId String?          @map("related_withdrawal_id")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  resolvedAt          DateTime?        @map("resolved_at") @db.Timestamptz(6)
  messages            SupportMessage[]
  assignee            AdminUser?       @relation(fields: [assignedTo], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

